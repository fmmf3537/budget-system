# Copy to `.env` and fill in values. Never commit `.env`.

# PostgreSQL connection string for Prisma
# https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/budget_system?schema=public"

# Empty DB for `prisma migrate dev` shadow (Prisma 7: set in prisma.config.ts). Create with:
#   CREATE DATABASE budget_system_shadow OWNER "your_app_user";
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/budget_system_shadow?schema=public"

# JWT 会话签名密钥（至少 32 字符；生产环境必填）
AUTH_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# 设为 0 时关闭 Mock 请求头回退，未携带有效会话 Cookie 的 API 将返回 401
# AUTH_ALLOW_MOCK_HEADERS=1

# Optional: defaults for mock API user/org (overridable via x-mock-user-id / x-mock-org-id)
# MOCK_USER_ID=demo-user
# MOCK_ORG_ID=demo-org
